{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Audie",
  "version": "0.0.0",
  "identifier": "com.aubergine.audie",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Audie",
        "width": 960,
        "height": 640,
        "resizable": false,
        "maximizable": false,
        "url": "index.html",
        "theme": "Dark",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      },
      {
        "label": "overlay",
        "title": "Audie Overlay",
        "url": "overlay.html",
        "width": 320,
        "height": 56,
        "visible": false,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "focus": false,
        "shadow": false,
        "acceptFirstMouse": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
